# MiniPrem unattended-install seed file
#
# Usage:
#   sudo ./docker/scripts/install_miniprem.sh --seed /path/to/your.seed.env
#
# Format:
#   - Plain shell KEY=value lines (sourced; quoting and comments work).
#   - Every key is prefixed MINIPREM_SEED_ — anything else is ignored with a
#     warning at load time (typo guard).
#   - --seed implies --non-interactive. Add --interactive on the CLI to enable
#     mixed mode (seed values plus prompts for anything missing).
#   - Missing required keys are reported in one batch before any destructive
#     work begins.
#
# Precedence (highest wins):
#   1. CLI flags on install_miniprem.sh   (e.g. --platform-key=XXX)
#   2. Values in this seed file
#   3. Interactive prompts (non-interactive mode never reaches this layer)
#
# Security:
#   - This file contains credentials. Restrict permissions: chmod 600
#   - Don't commit per-customer seed files to git (see .gitignore).
#   - Hand the file to third parties via a secure channel, then have them
#     wipe it after install.

# ---------------------------------------------------------------------------
# Required: install shape
# ---------------------------------------------------------------------------

# default = Renny + monitor only
# full    = Renny + Flowise + vLLM + Grafana + Prometheus + RIME + Whisper
MINIPREM_SEED_INSTALL_TYPE=default

# yes = install /etc/systemd/system/miniprem.service so MiniPrem auto-starts
#       at boot regardless of which user logs in (recommended for kiosks).
# no  = manual start via ./miniprem.sh start
MINIPREM_SEED_INSTALL_AS_SERVICE=yes

# yes = anonymous heartbeat telemetry to renny.services.uneeq.io
# no  = telemetry disabled
# (No silent default — must be explicit under unattended installs.)
MINIPREM_SEED_TELEMETRY_CONSENT=yes

# hardware = on-prem PC/kiosk (high-fidelity rendering)
# cloud    = cloud GPU instance (performance-optimized rendering)
MINIPREM_SEED_DEPLOYMENT_TARGET=hardware

# UneeQ platform region. Default is us if unset.
# us | eu
MINIPREM_SEED_REGION=us

# ---------------------------------------------------------------------------
# Required: UneeQ platform credentials
# ---------------------------------------------------------------------------

MINIPREM_SEED_PLATFORM_KEY=
MINIPREM_SEED_TENANT_ID=
MINIPREM_SEED_RENNY_IMAGE=cr.uneeq.io/uneeq/renny-renderer:enterprise-latest

# Optional: explicit DHOP wss:// address. If unset, derived from REGION.
# MINIPREM_SEED_PLATFORM_ADDRESS=wss://api.enterprise.uneeq.io/signalling-service/v1/ws/renderer

# ---------------------------------------------------------------------------
# Required: Harbor (cr.uneeq.io) registry credentials
# ---------------------------------------------------------------------------
# Robot account credentials issued by UneeQ. Username typically starts with
# "robot$". Contact help@uneeq.com if you don't have these.
#
# IMPORTANT: any value containing $ MUST be wrapped in *single* quotes so
# the shell doesn't try to expand it as a variable reference. Double quotes
# are not sufficient. Example:
#   MINIPREM_SEED_HARBOR_USERNAME='robot$customer-name'

MINIPREM_SEED_HARBOR_USERNAME=
MINIPREM_SEED_HARBOR_PASSWORD=

# ---------------------------------------------------------------------------
# Required: Text-to-speech provider (pick one path; only fill its keys)
# ---------------------------------------------------------------------------

# azure | elevenlabs | rime
MINIPREM_SEED_TTS_PROVIDER=azure

# Azure TTS — required when TTS_PROVIDER=azure
MINIPREM_SEED_AZURE_REGION=
MINIPREM_SEED_AZURE_SPEECH_KEY=

# Eleven Labs TTS — required when TTS_PROVIDER=elevenlabs
# MINIPREM_SEED_ELEVEN_LABS_API_KEY=

# RIME TTS — required when TTS_PROVIDER=rime
# MINIPREM_SEED_RIME_API_KEY=
# MINIPREM_SEED_RIME_QUAY_PASSWORD=     # quay.io password for rimelabs+uneeq

# ---------------------------------------------------------------------------
# Required for full installs: speech-to-text backend
# ---------------------------------------------------------------------------
# Only consulted when MINIPREM_SEED_INSTALL_TYPE=full.
# whisper     = OpenAI Whisper (CPU)
# fastwhisper = GPU-optimized FastWhisper (locally built)
# none        = no local STT (use UneeQ-hosted)
# MINIPREM_SEED_STT_PROVIDER=none

# ---------------------------------------------------------------------------
# Optional: custom Docker services
# ---------------------------------------------------------------------------
# Set to yes AND point CUSTOM_SERVICES_FILE at a pre-authored
# docker-compose.custom.yml to install custom services unattended.
# Without a file, non-interactive runs skip this step (cannot open editor).
# MINIPREM_SEED_CUSTOM_SERVICES=no
# MINIPREM_SEED_CUSTOM_SERVICES_FILE=/path/to/docker-compose.custom.yml

# ---------------------------------------------------------------------------
# NVIDIA all-in-one stack (Kubernetes/kubeadm path only)
# ---------------------------------------------------------------------------
# Consumed by kubernetes/scripts/deploy-allinone.sh, which stands up the full
# on-box stack: NIM (Gemma) + Riva TTS/STT + NVIDIA RAG blueprint + the
# UneeQ<->RAG adapter (+ Redis) + Phoenix + Renny + the Dell kiosk.
#
# Only relevant when deploying the all-in-one (not the Docker default/full
# paths). The installer maps these MINIPREM_SEED_* keys to the env vars
# deploy-allinone.sh reads.

# yes = deploy the full NVIDIA RAG all-in-one stack on this box.
# MINIPREM_SEED_ALLINONE=no

# NVIDIA NGC API key — pulls NIM models (Gemma, embed, rerank, Riva) and the
# NVIDIA RAG blueprint chart. Required when ALLINONE=yes. Starts with "nvapi-".
# MINIPREM_SEED_NGC_API_KEY=

# Gemma NIM model id served as the RAG LLM. Recommended: gemma-2-9b-it (pullable
# with a standard NGC key; fits alongside Riva STT/TTS + Renny + RAG). gemma-3-1b-it
# for a tight GPU; gemma-3-27b-it needs an extra NGC entitlement (pull 401s without it).
# MINIPREM_SEED_GEMMA_MODEL=google/gemma-2-9b-it

# Gemma serving backend: vllm (default) | nim (NIM operator, NV-FP4 — preferred
# on Blackwell / RTX 6000 so the model shares the GPU via time-slicing).
# MINIPREM_SEED_GEMMA_BACKEND=vllm

# Kiosk speech-to-text provider for the all-in-one box:
#   riva     = on-prem NVIDIA Riva (no cloud, default for all-in-one)
#   deepgram = cloud Deepgram (requires a Deepgram key in the kiosk backend)
# MINIPREM_SEED_KIOSK_STT_PROVIDER=riva

# Kiosk branding variant: dell | uneeq (builds VITE_BRAND).
# MINIPREM_SEED_KIOSK_BRAND=dell

# Optional shared secret protecting the adapter's /admin/* endpoints (kiosk
# prompt + document management). Empty = open (on-box only).
# MINIPREM_SEED_RAG_ADMIN_KEY=

# ---------------------------------------------------------------------------
# Optional: confirmation override
# ---------------------------------------------------------------------------
# yes = auto-accept all "continue?" gates (port conflicts, duplicate install
#       detected, merge conflicts, etc.). Equivalent to --force on the CLI.
#       Use deliberately — it overrides safety prompts.
# no  = abort on any "continue?" gate (default).
# MINIPREM_SEED_FORCE=no
