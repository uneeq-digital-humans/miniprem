{
  "name": "miniprem-monitor-frontend",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for Docker and Kubernetes",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test:e2e": "node scripts/e2e-tests.js",
    "test:dashboard": "node scripts/dashboard-test.js",
    "test:monitoring": "node scripts/monitoring-test.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:setup": "playwright test --project=setup",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:mobile": "playwright test --project=mobile",
    "test:api": "playwright test api.spec.ts",
    "test:components": "playwright test components.spec.ts",
    "test:websocket": "playwright test websocket.spec.ts",
    "test:visual": "playwright test visual-regression.spec.ts",
    "test:visual-update": "playwright test visual-regression.spec.ts --update-snapshots",
    "test:performance": "playwright test performance.spec.ts --reporter=json",
    "test:perf-headed": "playwright test performance.spec.ts --headed"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.18",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@xterm/xterm": "^5.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "autoprefixer": "^10.4.16",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.294.0",
    "next": "^15.5.3",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.8.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.54.0",
    "eslint-config-next": "^15.5.3"
  }
}
