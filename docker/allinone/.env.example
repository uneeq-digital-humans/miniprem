# UneeQ + NVIDIA all-in-one — copy to .env and fill in. Keep .env out of git.

# --- NVIDIA ---------------------------------------------------------------
# NGC API key (pulls all NIMs: Gemma, Riva TTS/STT, embed, rerank). Starts "nvapi-".
NGC_API_KEY=
# Optional: pin the Gemma NIM profile (NVFP4) for your GPU (see NGC model card).
GEMMA_NIM_PROFILE=

# --- UneeQ platform (Renny) ----------------------------------------------
# From the UneeQ Admin Portal / DHOP. Required for the renderer to connect.
PLATFORM_KEY=
TENANT_ID=
# DHOP endpoints default to enterprise.uneeq.io (US). Override for EU if needed.
# DHOP_ADDRESS=wss://api-eu.enterprise.uneeq.io/signalling-service/v2/ws/renderer

# --- Renny image (UneeQ Harbor) ------------------------------------------
# `docker login cr.uneeq.io` with your robot account before `up.sh`.
RENNY_IMAGE=cr.uneeq.io/uneeq/renny-renderer:0.1184-2f3b7

# --- TTS for Renny (gestures animate on ElevenLabs/Azure; Riva TTS drops tags) -
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_MODEL_ID=eleven_flash_v2_5
# or Azure:
AZURE_SPEECH_KEY=
AZURE_REGION=

# --- Kiosk ---------------------------------------------------------------
# dell | uneeq  (brand baked at build)
KIOSK_BRAND=dell

# --- RAG profile (optional) ----------------------------------------------
# Path to the cloned NVIDIA RAG blueprint compose (enables --profile rag).
# RAG_COMPOSE=./nvidia-rag/deploy/compose/docker-compose-rag-server.yaml
