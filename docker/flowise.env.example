# Flowise secrets and admin account for the MiniPrem full install.
#
# DO NOT use this file directly. The installer (docker/scripts/install_miniprem.sh)
# generates docker/flowise.env from this template with random values.
# To regenerate manually:
#   cp flowise.env.example flowise.env
#   then replace each CHANGE_ME with: openssl rand -hex 32
#
# NOTE: changing FLOWISE_SECRETKEY_OVERWRITE after Flowise has stored credentials
# makes those credentials undecryptable — wipe the flowise_data volume if you do.

# Encryption key for credentials stored in Flowise
FLOWISE_SECRETKEY_OVERWRITE=CHANGE_ME

# Auth/session secrets — must stay stable across container restarts, otherwise
# logins are invalidated on every restart (login redirect loop).
JWT_AUTH_TOKEN_SECRET=CHANGE_ME
JWT_REFRESH_TOKEN_SECRET=CHANGE_ME
EXPRESS_SESSION_SECRET=CHANGE_ME
TOKEN_HASH_SECRET=CHANGE_ME

# Initial Flowise admin account, created automatically by the chatflow setup
# script (setup-chatflow-post-deployment.sh). Use these to log in at
# http://localhost:3000. Password must contain upper, lower, digit and a
# special character (Flowise enforces this).
FLOWISE_ADMIN_EMAIL=admin@miniprem.local
FLOWISE_ADMIN_PASSWORD=CHANGE_ME
