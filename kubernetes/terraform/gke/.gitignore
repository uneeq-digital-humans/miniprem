# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json

# Allow example tfvars
!*.example.tfvars
!terraform.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Lock file
.terraform.lock.hcl

# Ignore Mac files
.DS_Store

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo
*~
