# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform directory
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Kubeconfig files
kubeconfig
*.kubeconfig

# Azure credentials (if accidentally stored)
.azure/
*.subscription

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Backup files
*.bak
*.backup

# Sensitive variable files (use terraform.tfvars but keep example)
# Uncomment this if you want to exclude terraform.tfvars from git:
# terraform.tfvars
